---
import { CONTACT } from "../consts";

interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = "Ready for an easy day?",
  subheading = "Schedule your notarization online in minutes, or text us to talk through what you need. Texting is the fastest way to reach us.",
} = Astro.props;
---

<section class="border-t border-line bg-ink">
  <div class="container-page flex flex-col items-start gap-8 py-20 md:flex-row md:items-center md:justify-between">
    <div class="max-w-xl">
      <h2 class="font-display text-3xl font-semibold text-paper md:text-4xl">{heading}</h2>
      <p class="mt-3 text-base leading-relaxed text-white/60">{subheading}</p>
    </div>
    <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
      <a href="/schedule" class="btn bg-paper text-ink hover:bg-seal-light">
        Schedule Appointment
      </a>
      <a href={CONTACT.smsHref} class="btn border border-white/25 text-paper hover:border-white/50">
        Text {CONTACT.phoneDisplay}
      </a>
    </div>
  </div>
</section>
