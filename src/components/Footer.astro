---
import { SITE, CONTACT, NAV_LINKS, SERVICE_LINKS, LEGAL_LINKS } from "../consts";

const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-paper">
  <div class="container-page py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-[1.3fr_1fr_1fr_1fr]">
      <div>
        <a href="/" class="inline-flex" aria-label="Easy Day Notary home">
          <img
            src="/images/easyday-logo.png"
            alt="Easy Day Notary"
            class="h-16 w-auto"
            width="320"
            height="116"
          />
        </a>
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-ink">
          Licensed Florida mobile &amp; remote online notary. Documents notarized
          correctly, on your schedule, wherever you are.
        </p>
      </div>

      <div>
        <h3 class="eyebrow">Company</h3>
        <ul class="mt-4 space-y-3 text-sm">
          {NAV_LINKS.map((link) => (
            <li><a href={link.href} class="text-ink hover:text-seal-dark">{link.label}</a></li>
          ))}
          <li><a href="/schedule" class="text-ink hover:text-seal-dark">Schedule</a></li>
        </ul>
      </div>

      <div>
        <h3 class="eyebrow">Services</h3>
        <ul class="mt-4 space-y-3 text-sm">
          {SERVICE_LINKS.map((link) => (
            <li><a href={link.href} class="text-ink hover:text-seal-dark">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="eyebrow">Contact</h3>
        <ul class="mt-4 space-y-3 text-sm text-ink">
          <!-- TODO: Confirm final phone / email / hours before launch -->
          <li>
            <a href={CONTACT.smsHref} class="hover:text-seal-dark">{CONTACT.phoneDisplay}</a>
            <span class="block text-xs text-slate-light">Text is the fastest way to get a response</span>
          </li>
          <li><a href={`mailto:${CONTACT.email}`} class="hover:text-seal-dark">{CONTACT.email}</a></li>
          <li class="text-slate">{CONTACT.serviceArea}</li>
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-line pt-8 text-sm text-slate-light md:flex-row md:items-center">
      <p>&copy; {year} {SITE.name}. All rights reserved.</p>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        {LEGAL_LINKS.map((link) => (
          <a href={link.href} class="hover:text-ink">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
