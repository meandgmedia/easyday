---
import { NAV_LINKS, CONTACT } from "../consts";

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="sticky top-0 z-50 border-b border-line/80 bg-paper/85 backdrop-blur-md">
  <div class="container-page flex h-18 items-center justify-between py-3">
    <a href="/" class="flex shrink-0 items-center gap-2" aria-label="Easy Day Notary home">
      <img
        src="/images/easyday-logo.png"
        alt="Easy Day Notary"
        class="h-10 w-auto md:h-11"
        width="220"
        height="80"
      />
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-display text-[0.95rem] font-medium transition-colors",
            isActive(link.href)
              ? "text-ink"
              : "text-slate hover:text-ink",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a href={CONTACT.phoneHref} class="btn btn-secondary">
        Call Now
      </a>
      <a href="/schedule" class="btn btn-primary">
        Schedule Appointment
      </a>
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-line md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-line md:hidden">
    <nav class="container-page flex flex-col gap-1 py-4" aria-label="Mobile">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            "rounded-lg px-3 py-3 font-display text-base font-medium",
            isActive(link.href) ? "bg-stone text-ink" : "text-slate hover:bg-stone hover:text-ink",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
      <div class="mt-2 flex flex-col gap-2 border-t border-line pt-4">
        <a href={CONTACT.phoneHref} class="btn btn-secondary w-full">Call Now</a>
        <a href="/schedule" class="btn btn-primary w-full">Schedule Appointment</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isHidden = menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", isHidden ? "true" : "false");
    toggle.setAttribute("aria-label", isHidden ? "Close menu" : "Open menu");
  });

  // Close the mobile menu whenever a nav link is tapped.
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
