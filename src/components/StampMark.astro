---
interface Props {
  class?: string;
  label?: string;
}

const { class: className = "", label = "NOTARIZED" } = Astro.props;
---

<div class:list={["seal-ring flex flex-col items-center justify-center text-center", className]} aria-hidden="true">
  <svg viewBox="0 0 100 100" class="absolute inset-0 h-full w-full">
    <circle cx="50" cy="50" r="47" fill="none" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2 3" class="text-ink" />
  </svg>
  <span class="font-mono text-[0.55rem] tracking-[0.25em] text-seal">{label}</span>
  <span class="mt-1 font-mono text-[0.5rem] tracking-[0.2em] text-slate-light">FL &middot; EST.</span>
</div>
