---
interface Props {
  quote: string;
  name: string;
  role: string;
}

const { quote, name, role } = Astro.props;
---

<figure class="card flex h-full flex-col justify-between p-7">
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-line" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
    <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14h-6c0-2.2 1.8-4 4-4V8h-2Zm14 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-2.2 1.8-4 4-4V8h-2Z" />
  </svg>
  <blockquote class="mt-4 flex-1 text-[0.98rem] leading-relaxed text-ink">
    <p>&ldquo;{quote}&rdquo;</p>
  </blockquote>
  <figcaption class="mt-6 border-t border-line pt-4">
    <p class="font-display text-sm font-semibold text-ink">{name}</p>
    <p class="text-sm text-slate">{role}</p>
  </figcaption>
</figure>
