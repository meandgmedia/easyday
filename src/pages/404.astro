---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found"
  description="The page you're looking for couldn't be found."
  path="/404"
  noindex={true}
>
  <section class="flex min-h-[60vh] items-center justify-center py-24">
    <div class="container-page flex flex-col items-center text-center">
      <span class="eyebrow">404</span>
      <h1 class="mt-4 font-display text-4xl font-bold text-ink sm:text-5xl">
        This page wasn't found.
      </h1>
      <p class="mt-5 max-w-md text-lg leading-relaxed text-slate">
        The page you're looking for may have moved or no longer exists.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/contact" class="btn btn-secondary">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>
