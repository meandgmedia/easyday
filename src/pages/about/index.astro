---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CtaBand from "../../components/CtaBand.astro";
import StampMark from "../../components/StampMark.astro";
import { breadcrumbSchema } from "../../lib/schema";

const crumbs = [
  { name: "Home", path: "/" },
  { name: "About", path: "/about" },
];

const values = [
  {
    title: "Professionalism",
    body: "Every appointment is treated with the same care as a courtroom filing — accurate, punctual, and properly documented.",
  },
  {
    title: "Accessibility",
    body: "Notarization shouldn't require taking half a day off work. Mobile and online options meet you where you are.",
  },
  {
    title: "Integrity",
    body: "A notary's job is to protect against fraud. I follow Florida notary law closely, with no shortcuts, ever.",
  },
  {
    title: "Clarity",
    body: "Straightforward pricing, clear appointment windows, and honest answers about what a notarization can and can't do.",
  },
];
---

<Layout
  title="About Easy Day Notary"
  description="Meet Easy Day Notary — a licensed Florida Notary Public offering mobile and remote online notarizations with professionalism and care."
  path="/about"
  jsonLd={breadcrumbSchema(crumbs)}
>
  <Breadcrumbs items={crumbs} />

  <section class="border-b border-line py-20 md:py-28">
    <div class="container-page grid grid-cols-1 gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <span class="eyebrow">About</span>
        <h1 class="mt-4 font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">
          A licensed notary who treats your paperwork like it matters.
        </h1>
        <div class="mt-8 space-y-5 text-lg leading-relaxed text-slate">
          <p>
            Easy Day Notary is a Florida-commissioned Notary Public providing
            mobile and Remote Online Notarization services. The goal is
            simple: make one of life's small, occasionally stressful tasks —
            getting a document properly signed and sealed — as painless as
            possible.
          </p>
          <!-- TODO: Add Florida notary commission number and E&O/bond policy details once available -->
          <p>
            Hi, I'm Matt! Originally from San Diego, California, I now
            proudly call Vero Beach, Florida home. I'm a licensed, insured,
            and bonded Florida Notary Public, and I also work full-time as a
            licensed insurance agent based in Vero Beach, specializing in
            personal lines — auto, home, boats, and more — with licensing in
            all 50 states. Before that, I served in the United States Navy
            as a Mass Communication Specialist, and later worked as an
            acquisitions analyst and real estate buyer's agent in San Diego.
            Along the way, I've traveled the world chasing good waves, great
            food, and new cultures — an experience that's given me a real
            appreciation for how much careful, well-prepared documentation
            matters, in business and in life. I'm always happy to help, so
            don't hesitate to reach out. Thank you for visiting Easy Day
            Notary!
          </p>
        </div>
      </div>
      <div class="relative mx-auto flex w-full max-w-sm items-center justify-center">
        <img
          src="/images/matt-portrait.jpg"
          alt="Matt, founder of Easy Day Notary"
          class="aspect-[4/5] w-full rounded-2xl border border-line object-cover shadow-lift"
          width="1000"
          height="780"
        />
        <StampMark class="absolute -bottom-5 -right-5 h-24 w-24 bg-paper shadow-soft" />
      </div>
    </div>
  </section>

  <section class="border-b border-line py-16 md:py-20">
    <div class="container-page grid grid-cols-1 items-center gap-10 md:grid-cols-[0.9fr_1.1fr]">
      <img
        src="/images/matt-surfing.jpg"
        alt="Matt surfing"
        class="aspect-[3/2] w-full rounded-2xl border border-line object-cover shadow-soft"
        width="1200"
        height="800"
      />
      <div>
        <span class="eyebrow">Outside the Office</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-ink">
          When I'm not notarizing, I'm probably chasing a wave.
        </h2>
        <p class="mt-4 text-[0.98rem] leading-relaxed text-slate">
          A San Diego upbringing and a fair bit of world travel left me with
          a genuine love of surfing, good food, and new places — and a
          steady, easygoing approach that carries over into every
          appointment I run.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-line bg-stone py-20 md:py-24">
    <div class="container-page grid grid-cols-1 gap-10 md:grid-cols-2">
      <div class="card p-8">
        <span class="eyebrow">Mission</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-ink">
          Remove the friction from getting documents notarized.
        </h2>
        <p class="mt-4 text-[0.98rem] leading-relaxed text-slate">
          <!-- TODO: Personalize your mission statement -->
          To provide Florida signers with reliable, professional notary
          services that fit their schedule — not the other way around —
          whether that means driving to a hospital room or logging on for a
          video session at 9 p.m.
        </p>
      </div>
      <div class="card p-8">
        <span class="eyebrow">Commitment</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-ink">
          Licensed, mobile, and remote-ready.
        </h2>
        <ul class="mt-4 space-y-3 text-[0.98rem] leading-relaxed text-slate">
          <li class="flex gap-3">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-seal"></span>
            Commissioned Florida Notary Public
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-seal"></span>
            Mobile Notary serving the local Florida community
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-seal"></span>
            Remote Online Notary (RON) commissioned for statewide sessions
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24">
    <div class="container-page">
      <span class="eyebrow">Values</span>
      <h2 class="mt-4 max-w-xl font-display text-3xl font-semibold text-ink md:text-4xl">
        What guides every appointment.
      </h2>
      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2">
        {values.map((value) => (
          <div class="border-t-2 border-ink pt-5">
            <h3 class="font-display text-lg font-semibold text-ink">{value.title}</h3>
            <p class="mt-2 text-[0.95rem] leading-relaxed text-slate">{value.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
