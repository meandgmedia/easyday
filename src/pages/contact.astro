---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { breadcrumbSchema } from "../lib/schema";
import { CONTACT } from "../consts";

const crumbs = [
  { name: "Home", path: "/" },
  { name: "Contact", path: "/contact" },
];
---

<Layout
  title="Contact Easy Day Notary"
  description="Get in touch with Easy Day Notary to schedule a mobile or remote online notarization, or ask a question about our services."
  path="/contact"
  jsonLd={breadcrumbSchema(crumbs)}
>
  <Breadcrumbs items={crumbs} />

  <section class="py-16 md:py-20">
    <div class="container-page grid grid-cols-1 gap-14 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <span class="eyebrow">Contact</span>
        <h1 class="mt-4 font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">
          Let's get it signed.
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate">
          Reach out with your document details and preferred appointment
          time — mobile or Remote Online Notarization.
        </p>

        <dl class="mt-10 space-y-8">
          <div class="border-t border-line pt-5">
            <dt class="eyebrow">Text</dt>
            <dd class="mt-2">
              <a href={CONTACT.smsHref} class="font-display text-xl font-semibold text-ink hover:text-seal-dark">
                {CONTACT.phoneDisplay}
              </a>
              <p class="mt-1 text-sm text-slate">Text is the fastest way to get a response.</p>
            </dd>
          </div>
          <div class="border-t border-line pt-5">
            <dt class="eyebrow">Email</dt>
            <!-- TODO: Replace placeholder email in src/consts.ts -->
            <dd class="mt-2">
              <a href={`mailto:${CONTACT.email}`} class="font-display text-xl font-semibold text-ink hover:text-seal-dark">
                {CONTACT.email}
              </a>
            </dd>
          </div>
          <div class="border-t border-line pt-5">
            <dt class="eyebrow">Business Hours</dt>
            <dd class="mt-3 space-y-1.5">
              {CONTACT.hours.map((h) => (
                <div class="flex justify-between gap-6 text-sm text-slate">
                  <span>{h.day}</span>
                  <span class="font-medium text-ink">{h.time}</span>
                </div>
              ))}
            </dd>
          </div>
          <div class="border-t border-line pt-5">
            <dt class="eyebrow">Service Area</dt>
            <dd class="mt-2 text-[0.98rem] leading-relaxed text-slate">
              {CONTACT.serviceArea}. Remote Online Notarization available
              statewide.
            </dd>
          </div>
        </dl>
      </div>

      <div>
        <!-- ============ CONTACT FORM (Web3Forms) ============ -->
        <div class="card p-8">
          <h2 class="font-display text-xl font-semibold text-ink">Send a Message</h2>
          <p class="mt-2 text-sm text-slate">
            Fill out the form and we'll get back to you promptly. Prefer to
            text? {CONTACT.phoneDisplay} is the fastest way to reach us.
          </p>

          <form id="contact-form" class="mt-6 space-y-5">
            <input type="hidden" name="access_key" value="a20ae3fc-a215-4beb-af7e-0d424c70aab9" />
            <input type="hidden" name="subject" value="New message from easydaynotary.com" />
            <input type="hidden" name="from_name" value="Easy Day Notary Website" />
            <!-- Honeypot spam trap — kept off-screen, real visitors never fill it in -->
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

            <div>
              <label for="name" class="mb-1.5 block text-sm font-medium text-ink">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Jane Signer"
                class="w-full rounded-lg border border-line bg-stone px-4 py-3 text-sm text-ink placeholder:text-slate-light focus:border-ink focus:bg-paper"
              />
            </div>
            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-ink">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="jane@example.com"
                class="w-full rounded-lg border border-line bg-stone px-4 py-3 text-sm text-ink placeholder:text-slate-light focus:border-ink focus:bg-paper"
              />
            </div>
            <div>
              <label for="phone" class="mb-1.5 block text-sm font-medium text-ink">Phone <span class="font-normal text-slate-light">(optional)</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="(772) 555-0100"
                class="w-full rounded-lg border border-line bg-stone px-4 py-3 text-sm text-ink placeholder:text-slate-light focus:border-ink focus:bg-paper"
              />
            </div>
            <div>
              <label for="message" class="mb-1.5 block text-sm font-medium text-ink">Message</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                placeholder="Tell us what you need notarized and when..."
                class="w-full rounded-lg border border-line bg-stone px-4 py-3 text-sm text-ink placeholder:text-slate-light focus:border-ink focus:bg-paper"
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full">
              Send Message
            </button>
            <p id="contact-form-status" class="text-center text-sm" role="status" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById("contact-form");
    const status = document.getElementById("contact-form-status");

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const submitButton = form.querySelector("button[type='submit']");
      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      submitButton.disabled = true;
      submitButton.textContent = "Sending...";
      status.textContent = "";
      status.className = "text-center text-sm";

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify(payload),
        });
        const result = await response.json();

        if (result.success) {
          form.reset();
          status.textContent = "Thanks — your message has been sent. We'll be in touch shortly.";
          status.className = "text-center text-sm text-seal-dark";
        } else {
          status.textContent = "Something went wrong. Please try again, or text us directly.";
          status.className = "text-center text-sm text-red-600";
        }
      } catch (error) {
        status.textContent = "Something went wrong. Please try again, or text us directly.";
        status.className = "text-center text-sm text-red-600";
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = "Send Message";
      }
    });
  </script>
</Layout>
