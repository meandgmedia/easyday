---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { breadcrumbSchema } from "../lib/schema";
import { CONTACT } from "../consts";

const crumbs = [
  { name: "Home", path: "/" },
  { name: "Schedule", path: "/schedule" },
];
---

<Layout
  title="Schedule an Appointment"
  description="Schedule a mobile notary visit or Remote Online Notarization session with Easy Day Notary."
  path="/schedule"
  jsonLd={breadcrumbSchema(crumbs)}
>
  <Breadcrumbs items={crumbs} />

  <section class="border-b border-line py-16 md:py-20">
    <div class="container-page max-w-3xl">
      <span class="eyebrow">Schedule</span>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">
        Book your appointment.
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-slate">
        Choose whichever fits your document: an in-person mobile visit, or a
        Remote Online Notarization session. Prefer to talk it through first?
        Text {CONTACT.phoneDisplay} — it's the fastest way to get a response.
      </p>
    </div>
  </section>

  <section class="border-b border-line bg-stone py-16 md:py-20">
    <div class="container-page grid grid-cols-1 gap-10 lg:grid-cols-2">
      <!-- ============ MOBILE / IN-PERSON: CALENDLY EMBED ============ -->
      <div class="card flex flex-col p-8">
        <span class="eyebrow">In-Person</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-ink">Mobile Notary Visit</h2>
        <p class="mt-2 text-[0.95rem] leading-relaxed text-slate">
          Book a time for a notary to travel to your home, office, or another
          location in our service area.
        </p>

        <div class="mt-6 flex-1 overflow-hidden rounded-xl border border-line">
          <!-- Calendly inline widget begin -->
          <div class="calendly-inline-widget" data-url="https://calendly.com/easydaynotary/30min?primary_color=2e9b06" style="min-width:320px;height:700px;"></div>
          <script is:inline type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
          <!-- Calendly inline widget end -->
        </div>
      </div>

      <!-- ============ REMOTE ONLINE NOTARY: BLUENOTARY EMBED ============ -->
      <div class="card flex flex-col p-8">
        <span class="eyebrow">Online</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-ink">Remote Online Session</h2>
        <p class="mt-2 text-[0.95rem] leading-relaxed text-slate">
          Book a live video Remote Online Notarization session, available to
          signers anywhere in Florida.
        </p>

        <div
          id="bluenotary-embed-placeholder"
          class="mt-6 flex min-h-[420px] flex-1 flex-col items-center justify-center rounded-xl border-2 border-dashed border-line bg-paper p-6 text-center"
        >
          <!--
            TODO: Paste your BlueNotary embed / booking code here.
            Refer to BlueNotary's business dashboard for the correct embed
            snippet or scheduling link for your account.
          -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5 19.5 8.25v7.5l-3.75-2.25M4.5 6.75h9a1.5 1.5 0 0 1 1.5 1.5v7.5a1.5 1.5 0 0 1-1.5 1.5h-9a1.5 1.5 0 0 1-1.5-1.5v-7.5a1.5 1.5 0 0 1 1.5-1.5Z" />
          </svg>
          <p class="mt-4 font-display text-sm font-semibold text-ink">BlueNotary embed placeholder</p>
          <p class="mt-1 max-w-xs text-xs text-slate-light">
            This container is reserved for your BlueNotary session widget.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container-page max-w-2xl text-center mx-auto">
      <h2 class="font-display text-2xl font-semibold text-ink">Not sure which one you need?</h2>
      <p class="mt-3 text-[0.98rem] leading-relaxed text-slate">
        Read our guide on{" "}
        <a href="/blog/mobile-notary-vs-online-notary" class="link-underline font-semibold text-ink">
          Mobile Notary vs. Remote Online Notary
        </a>, or <a href="/contact" class="link-underline font-semibold text-ink">contact us</a> and we'll help you decide.
      </p>
    </div>
  </section>
</Layout>
