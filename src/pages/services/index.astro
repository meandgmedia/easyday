---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CtaBand from "../../components/CtaBand.astro";
import { breadcrumbSchema } from "../../lib/schema";

const crumbs = [
  { name: "Home", path: "/" },
  { name: "Services", path: "/services" },
];

const featured = [
  {
    title: "Mobile Notary",
    description:
      "A licensed notary travels to your home, office, hospital, or another location of your choice.",
    href: "/mobile-notary",
  },
  {
    title: "Remote Online Notary (RON)",
    description:
      "Meet a Florida-commissioned notary via secure live video and sign documents electronically.",
    href: "/remote-online-notary",
  },
  {
    title: "Loan Signing Agent",
    description:
      "Purchase, refinance, and HELOC packages handled accurately and on the title company's timeline.",
    href: "/loan-signings",
  },
];

const general = [
  {
    title: "General Notarizations",
    description:
      "Acknowledgments, jurats, and copy certifications for everyday personal and business documents.",
  },
  {
    title: "Power of Attorney",
    description:
      "Notarization for durable, medical, and limited powers of attorney, prepared for your review beforehand.",
  },
  {
    title: "Affidavits",
    description:
      "Sworn statements notarized correctly the first time, including name-change and identity affidavits.",
  },
  {
    title: "Real Estate Documents",
    description:
      "Deeds, mortgage documents, and closing paperwork notarized with the accuracy title work demands.",
  },
  {
    title: "Medical Documents",
    description:
      "Advance directives, healthcare surrogate designations, and HIPAA authorization forms.",
  },
  {
    title: "Travel Consent Forms",
    description:
      "Minor travel consent and authorization letters notarized ahead of domestic or international trips.",
  },
  {
    title: "Business Documents",
    description:
      "Corporate resolutions, LLC operating agreements, and contracts requiring a notarized signature.",
  },
  {
    title: "Apostille Preparation",
    description:
      "Guidance notarizing Florida documents destined for use in another country. See our apostille page for details.",
    href: "/apostille-services",
  },
];
---

<Layout
  title="Notary Services in Florida"
  description="Explore Easy Day Notary's full range of services: mobile notary, remote online notary, loan signings, power of attorney, real estate documents, and more."
  path="/services"
  jsonLd={breadcrumbSchema(crumbs)}
>
  <Breadcrumbs items={crumbs} />

  <section class="border-b border-line py-16 md:py-20">
    <div class="container-page max-w-3xl">
      <span class="eyebrow">Services</span>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">
        Notary services for every kind of document.
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-slate">
        From a single signature to a full loan signing package, Easy Day
        Notary handles it in person or online — always with attention to
        detail and Florida notary law.
      </p>
    </div>
  </section>

  <section class="border-b border-line bg-stone py-16 md:py-20">
    <div class="container-page">
      <h2 class="font-display text-2xl font-semibold text-ink">Core Services</h2>
      <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-3">
        {featured.map((service, i) => (
          <a href={service.href} class="card flex flex-col justify-between p-8">
            <div>
              <span class="eyebrow">0{i + 1}</span>
              <h3 class="mt-3 font-display text-xl font-semibold text-ink">{service.title}</h3>
              <p class="mt-2.5 text-[0.95rem] leading-relaxed text-slate">{service.description}</p>
            </div>
            <span class="mt-6 inline-flex items-center gap-1.5 font-display text-sm font-semibold text-ink">
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="container-page">
      <h2 class="font-display text-2xl font-semibold text-ink">Document Types We Notarize</h2>
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {general.map((service) => (
          <div class="card flex flex-col justify-between p-6">
            <div>
              <h3 class="font-display text-base font-semibold text-ink">{service.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate">{service.description}</p>
            </div>
            {service.href && (
              <a href={service.href} class="link-underline mt-4 inline-flex w-fit font-display text-sm font-semibold text-ink">
                Learn more →
              </a>
            )}
          </div>
        ))}
      </div>
      <p class="mt-8 text-sm text-slate">
        Don't see your document listed? <a href="/contact" class="link-underline font-semibold text-ink">Contact us</a> — most general notarizations can be accommodated.
      </p>
    </div>
  </section>

  <CtaBand />
</Layout>
