---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { breadcrumbSchema } from "../lib/schema";
import { SITE, CONTACT } from "../consts";

const crumbs = [
  { name: "Home", path: "/" },
  { name: "Terms of Service", path: "/terms" },
];

const lastUpdated = "July 16, 2026";
---

<Layout
  title="Terms of Service"
  description="Review the terms of service that govern your use of Easy Day Notary's website and notarization services."
  path="/terms"
  jsonLd={breadcrumbSchema(crumbs)}
>
  <Breadcrumbs items={crumbs} />

  <section class="py-16 md:py-20">
    <div class="container-page max-w-3xl">
      <span class="eyebrow">Legal</span>
      <h1 class="mt-4 font-display text-4xl font-bold text-ink">Terms of Service</h1>
      <p class="mt-3 text-sm text-slate-light">Last updated: {lastUpdated}</p>

      <!-- TODO: Have these terms reviewed by a Florida attorney before publishing -->
      <div class="mt-10 space-y-8 text-[0.98rem] leading-relaxed text-slate">
        <div>
          <h2 class="font-display text-xl font-semibold text-ink">1. Acceptance of Terms</h2>
          <p class="mt-3">
            By using {SITE.url} or scheduling services with {SITE.name}, you
            agree to these Terms of Service. If you do not agree, please
            discontinue use of the website and services.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">2. Nature of Services</h2>
          <p class="mt-3">
            {SITE.name} provides Florida notary public services, including
            mobile notarization, Remote Online Notarization (RON), and loan
            signing agent services. A notary public witnesses signatures and
            verifies identity; a notary does not provide legal advice and is
            not a substitute for an attorney.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">3. No Legal Advice</h2>
          <p class="mt-3">
            Nothing on this website constitutes legal advice. If you have
            questions about the legal effect of a document, consult a
            licensed attorney before your appointment.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">4. Appointments &amp; Cancellations</h2>
          <p class="mt-3">
            <!-- TODO: Insert your real cancellation / rescheduling / fee policy -->
            Appointment scheduling, cancellation windows, and any associated
            fees will be confirmed at the time of booking.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">5. Client Responsibilities</h2>
          <p class="mt-3">
            You are responsible for bringing valid, unexpired, government-issued
            photo identification and for ensuring you understand the
            document(s) you are signing. Documents must not be signed prior
            to your appointment.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">6. Right to Refuse Service</h2>
          <p class="mt-3">
            As required by Florida law, a notarization may be declined if
            identity cannot be verified, if the signer appears unwilling or
            incapable of understanding the document, or if the request falls
            outside what Florida notary law permits.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">7. Fees</h2>
          <p class="mt-3">
            Notary fees comply with limits set by Florida Statutes Chapter
            117. Mobile travel fees and loan signing fees, where applicable,
            are disclosed prior to your appointment.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">8. Limitation of Liability</h2>
          <p class="mt-3">
            {SITE.name} is not liable for indirect, incidental, or
            consequential damages arising from the use of this website or
            our services, to the fullest extent permitted by law.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink">9. Contact</h2>
          <p class="mt-3">
            Questions about these terms can be sent to
            {" "}<a href={`mailto:${CONTACT.email}`} class="link-underline font-semibold text-ink">{CONTACT.email}</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
